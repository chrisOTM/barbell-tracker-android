    <!-- seed exercise library -->
    <string name="seed_back_squat_name">Barbell Back Squat</string>
    <string name="seed_back_squat_muscles">Legs, glutes, core</string>
    <string name="seed_back_squat_desc">Bar on the upper back, squat down until the hips drop below the knees, back straight, then drive back up under control.</string>

    <string name="seed_bench_press_name">Bench Press</string>
    <string name="seed_bench_press_muscles">Chest, triceps, shoulders</string>
    <string name="seed_bench_press_desc">Lying on the flat bench, lower the bar to the chest and press straight up. Keep the shoulder blades pinched.</string>

    <string name="seed_deadlift_name">Deadlift</string>
    <string name="seed_deadlift_muscles">Back, legs, glutes</string>
    <string name="seed_deadlift_desc">Lift the bar off the floor with a straight back and extending hips until you stand upright. Keep the bar close to the body.</string>

    <string name="seed_barbell_row_name">Barbell Row</string>
    <string name="seed_barbell_row_muscles">Back, biceps</string>
    <string name="seed_barbell_row_desc">Bent over with a straight back, pull the bar to the lower chest, elbows close to the body.</string>

    <string name="seed_ohp_name">Overhead Press</string>
    <string name="seed_ohp_muscles">Shoulders, triceps</string>
    <string name="seed_ohp_desc">From standing, press the bar from shoulder height straight overhead, core tight. Also Military / Overhead Press.</string>

    <string name="seed_front_squat_name">Front Squat</string>
    <string name="seed_front_squat_muscles">Legs, core</string>
    <string name="seed_front_squat_desc">Rest the bar on the front shoulders, squat down upright and drive back up.</string>

    <string name="seed_lunges_name">Barbell Lunges</string>
    <string name="seed_lunges_muscles">Legs, glutes</string>
    <string name="seed_lunges_desc">Bar on the back, take large alternating steps forward and lower deep, front knee over the foot.</string>

    <string name="seed_good_mornings_name">Good Mornings</string>
    <string name="seed_good_mornings_muscles">Hamstrings, lower back</string>
    <string name="seed_good_mornings_desc">Bar on the back, hinge forward from the hips with a straight back, then stand back up.</string>

    <string name="seed_rdl_name">Romanian Deadlift</string>
    <string name="seed_rdl_muscles">Hamstrings, glutes, back</string>
    <string name="seed_rdl_desc">From standing with slightly bent knees, lower the bar along the legs, hips back, then stand up.</string>

    <string name="seed_one_arm_row_name">One-Arm Dumbbell Row</string>
    <string name="seed_one_arm_row_muscles">Back, biceps</string>
    <string name="seed_one_arm_row_desc">One hand and one knee on the bench, pull the dumbbell to the hip with the free hand.</string>

    <string name="seed_pullups_name">Pull-ups</string>
    <string name="seed_pullups_muscles">Back, biceps</string>
    <string name="seed_pullups_desc">Hanging from the bar, pull the body up until the chin clears the bar, then lower under control.</string>
