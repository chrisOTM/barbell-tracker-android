    <!-- seed exercise library -->
    <string name="seed_back_squat_name">Langhantel-Kniebeuge</string>
    <string name="seed_back_squat_muscles">Beine, Gesäß, Rumpf</string>
    <string name="seed_back_squat_desc">Langhantel im Nacken, tief in die Hocke gehen bis die Hüfte unter Kniehöhe ist, Rücken gerade, kontrolliert wieder hochdrücken.</string>

    <string name="seed_bench_press_name">Bankdrücken</string>
    <string name="seed_bench_press_muscles">Brust, Trizeps, Schultern</string>
    <string name="seed_bench_press_desc">Auf der Flachbank liegend die Langhantel zur Brust senken und gerade nach oben drücken. Schulterblätter zusammen.</string>

    <string name="seed_deadlift_name">Kreuzheben</string>
    <string name="seed_deadlift_muscles">Rücken, Beine, Gesäß</string>
    <string name="seed_deadlift_desc">Langhantel vom Boden mit geradem Rücken und gestreckter Hüfte anheben, bis du aufrecht stehst. Stange nah am Körper führen.</string>

    <string name="seed_barbell_row_name">Langhantel-Rudern</string>
    <string name="seed_barbell_row_muscles">Rücken, Bizeps</string>
    <string name="seed_barbell_row_desc">Vorgebeugt mit geradem Rücken die Langhantel zum unteren Brustkorb ziehen, Ellenbogen eng am Körper.</string>

    <string name="seed_ohp_name">Schulterdrücken</string>
    <string name="seed_ohp_muscles">Schultern, Trizeps</string>
    <string name="seed_ohp_desc">Aus dem Stand die Langhantel von Schulterhöhe gerade über den Kopf drücken, Rumpf fest. Auch Military / Overhead Press.</string>

    <string name="seed_front_squat_name">Frontkniebeuge</string>
    <string name="seed_front_squat_muscles">Beine, Rumpf</string>
    <string name="seed_front_squat_desc">Langhantel auf den vorderen Schultern ablegen, aufrecht in die Hocke gehen und wieder hochdrücken.</string>

    <string name="seed_lunges_name">Langhantel-Ausfallschritte</string>
    <string name="seed_lunges_muscles">Beine, Gesäß</string>
    <string name="seed_lunges_desc">Langhantel im Nacken, abwechselnd große Schritte nach vorn und tief absenken, vorderes Knie über dem Fuß.</string>

    <string name="seed_good_mornings_name">Good Mornings</string>
    <string name="seed_good_mornings_muscles">Beinbeuger, unterer Rücken</string>
    <string name="seed_good_mornings_desc">Langhantel im Nacken, mit geradem Rücken aus der Hüfte nach vorn beugen und wieder aufrichten.</string>

    <string name="seed_rdl_name">Rumänisches Kreuzheben</string>
    <string name="seed_rdl_muscles">Beinbeuger, Gesäß, Rücken</string>
    <string name="seed_rdl_desc">Aus dem Stand mit leicht gebeugten Knien die Stange entlang der Beine absenken, Hüfte nach hinten, dann aufrichten.</string>

    <string name="seed_one_arm_row_name">Kurzhantel-Rudern einarmig</string>
    <string name="seed_one_arm_row_muscles">Rücken, Bizeps</string>
    <string name="seed_one_arm_row_desc">Eine Hand und ein Knie auf der Bank, mit der freien Hand die Kurzhantel zur Hüfte ziehen.</string>

    <string name="seed_pullups_name">Klimmzüge</string>
    <string name="seed_pullups_muscles">Rücken, Bizeps</string>
    <string name="seed_pullups_desc">An der Stange hängend den Körper hochziehen bis das Kinn über der Stange ist, kontrolliert ablassen.</string>
